<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Amazon" verbose="1" parallel="false">

	<listeners>
		<listener class-name="io.qameta.allure.testng.AllureTestNg" />

	</listeners>

	<parameter name="browser" value="chrome" />
	<parameter name="runLocally" value="true" />
	<parameter name="implicitWait" value="10" />
	<parameter name="pageLoadTimeout" value="60" />

	<test name="AmazonTests">
		<classes>
			<class name="com.amazon.test.AmazonWebTest" />
		</classes>
	</test>

</suite>